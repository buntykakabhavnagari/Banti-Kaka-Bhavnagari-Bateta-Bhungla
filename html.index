<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bunty Kaka Bhavnagari - Bateka Bhungla</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <script src="https://cdn.tailwindcss.com"></script>
  
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              red: '#C23B22',
              cream: '#FFFCF7',
              dark: '#1A1A1A',
              muted: '#7A7A7A',
              border: '#E8E4DE',
              light: '#F5F2ED'
            }
          },
          fontFamily: {
            display: ['Playfair Display', 'serif'],
            sans: ['Inter', 'sans-serif']
          }
        }
      }
    }
  </script>
  
  <style>
    :root {
      --bg: #FFFCF7;
      --fg: #1A1A1A;
      --muted: #7A7A7A;
      --accent: #C23B22;
      --card: #FFFFFF;
      --border: #E8E4DE;
      --light: #F5F2ED;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    html {
      scroll-behavior: smooth;
    }
    
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--fg);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    
    ::selection {
      background: var(--accent);
      color: white;
    }
    
    ::-webkit-scrollbar {
      width: 6px;
    }
    ::-webkit-scrollbar-track {
      background: transparent;
    }
    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--muted);
    }
    
    /* Typography */
    .font-display {
      font-family: 'Playfair Display', serif;
    }
    
    /* Animations */
    @keyframes fadeUp {
      from { 
        opacity: 0; 
        transform: translateY(20px); 
      }
      to { 
        opacity: 1; 
        transform: translateY(0); 
      }
    }
    
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    
    @keyframes slideIn {
      from { 
        transform: translateX(100%); 
      }
      to { 
        transform: translateX(0); 
      }
    }
    
    @keyframes scaleIn {
      from { 
        opacity: 0;
        transform: scale(0.95); 
      }
      to { 
        opacity: 1;
        transform: scale(1); 
      }
    }
    
    .animate-fade-up {
      animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    .animate-fade-in {
      animation: fadeIn 0.6s ease-out forwards;
    }
    
    .animate-scale-in {
      animation: scaleIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    /* Reveal on Scroll */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }
    
    /* Button Styles */
    .btn-primary {
      background: var(--fg);
      color: var(--bg);
      padding: 14px 32px;
      border-radius: 60px;
      font-weight: 500;
      font-size: 14px;
      letter-spacing: 0.02em;
      border: none;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
      overflow: hidden;
    }
    
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }
    
    .btn-primary:active {
      transform: translateY(0);
    }
    
    .btn-secondary {
      background: transparent;
      color: var(--fg);
      padding: 14px 32px;
      border-radius: 60px;
      font-weight: 500;
      font-size: 14px;
      letter-spacing: 0.02em;
      border: 1.5px solid var(--border);
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .btn-secondary:hover {
      border-color: var(--fg);
      background: var(--fg);
      color: var(--bg);
    }
    
    /* Menu Card */
    .menu-card {
      background: var(--card);
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      border: 1px solid transparent;
    }
    
    .menu-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.06);
      border-color: var(--border);
    }
    
    /* Cart Sidebar */
    .cart-overlay {
      position: fixed;
      inset: 0;
      background: rgba(26, 26, 26, 0.4);
      backdrop-filter: blur(8px);
      z-index: 998;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s ease;
    }
    
    .cart-overlay.open {
      opacity: 1;
      pointer-events: all;
    }
    
    .cart-sidebar {
      position: fixed;
      top: 0;
      right: 0;
      width: 100%;
      max-width: 460px;
      height: 100vh;
      background: var(--bg);
      z-index: 999;
      transform: translateX(100%);
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      display: flex;
      flex-direction: column;
      box-shadow: -20px 0 60px rgba(0,0,0,0.1);
    }
    
    .cart-sidebar.open {
      transform: translateX(0);
    }
    
    /* Form Styles */
    .form-input {
      width: 100%;
      padding: 16px 20px;
      background: var(--card);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      font-size: 15px;
      font-family: inherit;
      transition: all 0.3s ease;
      color: var(--fg);
    }
    
    .form-input:focus {
      outline: none;
      border-color: var(--fg);
      box-shadow: 0 0 0 4px rgba(26, 26, 26, 0.05);
    }
    
    .form-input::placeholder {
      color: var(--muted);
    }
    
    /* Radio Button Custom */
    .radio-option {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 20px;
      background: var(--card);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    
    .radio-option:hover {
      border-color: var(--muted);
    }
    
    .radio-option.selected {
      border-color: var(--fg);
      background: var(--light);
    }
    
    .radio-dot {
      width: 20px;
      height: 20px;
      border: 2px solid var(--border);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
    }
    
    .radio-option.selected .radio-dot {
      border-color: var(--accent);
    }
    
    .radio-dot::after {
      content: '';
      width: 10px;
      height: 10px;
      background: var(--accent);
      border-radius: 50%;
      transform: scale(0);
      transition: transform 0.2s ease;
    }
    
    .radio-option.selected .radio-dot::after {
      transform: scale(1);
    }
    
    /* Quantity Control */
    .qty-btn {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      background: var(--card);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s ease;
      font-size: 18px;
      color: var(--fg);
    }
    
    .qty-btn:hover {
      border-color: var(--fg);
      background: var(--fg);
      color: var(--bg);
    }
    
    /* Badge */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      background: var(--light);
      color: var(--fg);
      font-size: 12px;
      font-weight: 500;
      border-radius: 100px;
      letter-spacing: 0.03em;
    }
    
    /* Spice Dot */
    .spice-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--border);
    }
    
    .spice-dot.active {
      background: var(--accent);
    }
    
    /* Focus States */
    button:focus-visible,
    a:focus-visible,
    input:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    
    /* Reduced Motion */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
    
    /* Smooth Image Loading */
    .img-loader {
      background: var(--light);
      animation: shimmer 1.5s infinite;
    }
    
    @keyframes shimmer {
      0% { opacity: 0.5; }
      50% { opacity: 1; }
      100% { opacity: 0.5; }
    }
    
    /* Transitions */
    .page-transition {
      transition: opacity 0.3s ease;
    }
  </style>
</head>
<body>
  
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-brand-cream/90 backdrop-blur-md border-b border-brand-border/50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 md:h-20">
        <a href="#" class="flex items-center gap-3">
          <div class="w-10 h-10 md:w-11 md:h-11 bg-brand-dark rounded-full flex items-center justify-center">
            <span class="font-display text-white text-sm md:text-base">BK</span>
          </div>
          <div>
            <p class="font-display text-base md:text-lg text-brand-dark leading-none">Bunty Kaka</p>
            <p class="text-[10px] md:text-xs text-brand-muted tracking-wider uppercase mt-0.5">Bhavnagari</p>
          </div>
        </a>
        
        <div class="hidden md:flex items-center gap-10">
          <a href="#menu" class="text-sm text-brand-dark/70 hover:text-brand-dark transition-colors">Menu</a>
          <a href="#story" class="text-sm text-brand-dark/70 hover:text-brand-dark transition-colors">Story</a>
          <a href="#location" class="text-sm text-brand-dark/70 hover:text-brand-dark transition-colors">Location</a>
        </div>
        
        <div class="flex items-center gap-4">
          <button onclick="openCart()" class="relative p-2 hover:bg-brand-light rounded-full transition-colors" aria-label="Open cart">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-dark">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            <span id="cartBadge" class="absolute -top-0.5 -right-0.5 w-5 h-5 bg-brand-red text-white text-[10px] rounded-full flex items-center justify-center font-medium opacity-0 scale-0 transition-all">0</span>
          </button>
          
          <button onclick="toggleMobileMenu()" class="md:hidden p-2" aria-label="Toggle menu">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-dark">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </nav>
  
  <!-- Mobile Menu -->
  <div id="mobileMenu" class="fixed inset-0 bg-brand-cream z-40 hidden opacity-0 transition-opacity duration-300">
    <div class="flex flex-col items-center justify-center h-full gap-8">
      <a href="#menu" onclick="toggleMobileMenu()" class="font-display text-3xl text-brand-dark">Menu</a>
      <a href="#story" onclick="toggleMobileMenu()" class="font-display text-3xl text-brand-dark">Story</a>
      <a href="#location" onclick="toggleMobileMenu()" class="font-display text-3xl text-brand-dark">Location</a>
    </div>
    <button onclick="toggleMobileMenu()" class="absolute top-5 right-6 p-2" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-dark">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  
  <!-- Hero Section -->
  <section class="min-h-screen pt-20 flex items-center">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12 md:py-20 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="order-2 lg:order-1 animate-fade-up">
          <div class="badge mb-6">
            <span class="w-1.5 h-1.5 bg-brand-red rounded-full"></span>
            Open Today 5:30 PM - 12:00 AM
          </div>
          
          <h1 class="font-display text-5xl md:text-6xl lg:text-7xl text-brand-dark leading-[1.1] mb-6">
            Authentic<br>
            <span class="text-brand-red">Kathiawadi</span><br>
            Bateka Bhungla
          </h1>
          
          <p class="text-lg text-brand-muted mb-8 max-w-md leading-relaxed">
            Bhavnagar na famous street food, now in Nikol. Traditional recipes passed down through generations.
          </p>
          
          <div class="flex flex-wrap gap-4">
            <button onclick="scrollToMenu()" class="btn-primary">
              View Menu
            </button>
            <a href="#location" class="btn-secondary">
              Find Us
            </a>
          </div>
          
          <div class="flex items-center gap-8 mt-12 pt-8 border-t border-brand-border">
            <div>
              <p class="font-display text-3xl text-brand-dark">4.9</p>
              <p class="text-sm text-brand-muted mt-1">Rating</p>
            </div>
            <div class="w-px h-12 bg-brand-border"></div>
            <div>
              <p class="font-display text-3xl text-brand-dark">500+</p>
              <p class="text-sm text-brand-muted mt-1">Daily Orders</p>
            </div>
            <div class="w-px h-12 bg-brand-border"></div>
            <div>
              <p class="font-display text-3xl text-brand-dark">2024</p>
              <p class="text-sm text-brand-muted mt-1">Est.</p>
            </div>
          </div>
        </div>
        
        <div class="order-1 lg:order-2 animate-fade-up" style="animation-delay: 0.2s;">
          <div class="relative">
            <div class="aspect-[4/5] rounded-3xl overflow-hidden bg-brand-light">
              <img src="https://z-cdn-media.chatglm.cn/files/0f3033a1-23bc-4bdf-87b4-2b55ea9c861a.png?auth_key=1873079545-5db6ed767255465a84d6d0fa54b5d7e8-0-00eb82b1ff88015bc124f902da1cbd4f" 
                   alt="Bateka Bhungla" 
                   class="w-full h-full object-cover hover:scale-105 transition-transform duration-700">
            </div>
            <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-5 shadow-xl border border-brand-border/50">
              <p class="text-sm text-brand-muted mb-1">Starting from</p>
              <p class="font-display text-3xl text-brand-dark">Rs 10</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Menu Section -->
  <section id="menu" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-sm text-brand-muted tracking-widest uppercase mb-4">Our Offerings</p>
        <h2 class="font-display text-4xl md:text-5xl text-brand-dark mb-4">The Menu</h2>
        <p class="text-brand-muted max-w-lg mx-auto">Each dish is crafted with authentic Kathiawadi spices and traditional cooking methods.</p>
      </div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8" id="menuGrid">
        <!-- Menu items rendered by JS -->
      </div>
    </div>
  </section>
  
  <!-- Story Section -->
  <section id="story" class="py-20 md:py-28 bg-brand-light">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="text-sm text-brand-muted tracking-widest uppercase mb-4">Our Story</p>
          <h2 class="font-display text-4xl md:text-5xl text-brand-dark mb-6">From Bhavnagar<br>to Your Heart</h2>
          <p class="text-brand-muted leading-relaxed mb-6">
            What started as a humble dream in the streets of Bhavnagar has found its home in Nikol. Bunty Kaka brought with him not just recipes, but generations of culinary wisdom.
          </p>
          <p class="text-brand-muted leading-relaxed mb-8">
            Every plate of Bateka Bhungla is a tribute to our roots — cooked in traditional iron kadai with spices ground the old-fashioned way.
          </p>
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-brand-dark rounded-full flex items-center justify-center">
              <span class="font-display text-white text-lg">BK</span>
            </div>
            <div>
              <p class="font-display text-lg text-brand-dark">Bunty Kaka</p>
              <p class="text-sm text-brand-muted">Founder & Chef</p>
            </div>
          </div>
        </div>
        
        <div class="reveal" style="transition-delay: 0.15s;">
          <div class="relative">
            <div class="aspect-square rounded-3xl overflow-hidden">
              <img src="https://z-cdn-media.chatglm.cn/files/f46cfece-aa3c-4182-b937-0d755a9bf3dd.jpg?auth_key=1873079545-939b1065e361456099acc33723517376-0-7c94ee61c520b8e8733b5cab25f4bbd9" 
                   alt="Food Cart" 
                   class="w-full h-full object-cover">
            </div>
            <div class="absolute -bottom-4 -right-4 md:-bottom-8 md:-right-8 bg-brand-dark text-white p-6 md:p-8 rounded-2xl">
              <p class="font-display text-4xl md:text-5xl">2024</p>
              <p class="text-sm text-white/60 mt-1">Established</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Location Section -->
  <section id="location" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <p class="text-sm text-brand-muted tracking-widest uppercase mb-4">Find Us</p>
          <h2 class="font-display text-4xl md:text-5xl text-brand-dark mb-8">Cart Location</h2>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-dark">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <p class="font-medium text-brand-dark mb-1">Location</p>
                <p class="text-brand-muted">Nikol, Ahmedabad, Gujarat</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-dark">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div>
                <p class="font-medium text-brand-dark mb-1">Opening Hours</p>
                <p class="text-brand-muted">Daily: 5:30 PM - 12:00 AM</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-dark">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <div>
                <p class="font-medium text-brand-dark mb-1">Contact</p>
                <p class="text-brand-muted">+91 9824847345</p>
              </div>
            </div>
          </div>
          
          <a href="https://maps.app.goo.gl/kiqJ2gdhNNmNhd5T9" target="_blank" rel="noopener noreferrer" class="btn-primary inline-flex mt-8">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mr-2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Get Directions
          </a>
        </div>
        
        <div class="reveal" style="transition-delay: 0.15s;">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-brand-border">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3671.9040861737367!2d72.65!3d23.05!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjPCsDAzJzAwLjAiTiA3MsKwMzknMDAuMCJF!5e0!3m2!1sen!2sin!4v1234567890"
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy"
              title="Location Map">
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Footer -->
  <footer class="py-12 bg-brand-dark text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center">
            <span class="font-display text-brand-dark text-sm">BK</span>
          </div>
          <div>
            <p class="font-display text-base">Bunty Kaka Bhavnagari</p>
            <p class="text-xs text-white/50">Since 2024</p>
          </div>
        </div>
        
        <p class="text-sm text-white/50">2024 All rights reserved. Made in Bhavnagar.</p>
      </div>
    </div>
  </footer>
  
  <!-- Cart Overlay -->
  <div class="cart-overlay" id="cartOverlay" onclick="closeCart()"></div>
  
  <!-- Cart Sidebar -->
  <aside class="cart-sidebar" id="cartSidebar" role="dialog" aria-label="Shopping cart">
    
    <!-- Step 1: Cart Items -->
    <div id="cartStep1" class="flex flex-col h-full">
      <div class="flex items-center justify-between p-6 border-b border-brand-border">
        <h3 class="font-display text-2xl text-brand-dark">Your Order</h3>
        <button onclick="closeCart()" class="p-2 hover:bg-brand-light rounded-full transition-colors" aria-label="Close cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-dark">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      
      <div class="flex-1 overflow-y-auto p-6" id="cartItemsContainer">
        <!-- Cart items -->
      </div>
      
      <div class="p-6 border-t border-brand-border bg-white">
        <div class="flex justify-between items-center mb-6">
          <span class="text-brand-muted">Subtotal</span>
          <span class="font-display text-2xl text-brand-dark" id="cartSubtotal">Rs 0</span>
        </div>
        <button onclick="proceedToCheckout()" id="checkoutBtn" class="btn-primary w-full" disabled>
          Proceed to Checkout
        </button>
      </div>
    </div>
    
    <!-- Step 2: Checkout Options -->
    <div id="cartStep2" class="flex flex-col h-full hidden">
      <div class="flex items-center gap-4 p-6 border-b border-brand-border">
        <button onclick="backToCart()" class="p-2 hover:bg-brand-light rounded-full transition-colors" aria-label="Go back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-dark">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
        </button>
        <h3 class="font-display text-2xl text-brand-dark">Checkout</h3>
      </div>
      
      <div class="flex-1 overflow-y-auto p-6">
        <p class="text-sm text-brand-muted mb-4">Select Order Type</p>
        
        <div class="space-y-3 mb-8">
          <div onclick="selectOrderType('pickup')" class="radio-option" data-type="pickup" role="radio" tabindex="0">
            <div class="radio-dot"></div>
            <div>
              <p class="font-medium text-brand-dark">Pickup</p>
              <p class="text-sm text-brand-muted">Collect from our cart location</p>
            </div>
          </div>
          
          <div onclick="selectOrderType('delivery')" class="radio-option" data-type="delivery" role="radio" tabindex="0">
            <div class="radio-dot"></div>
            <div>
              <p class="font-medium text-brand-dark">Delivery</p>
              <p class="text-sm text-brand-muted">Get it delivered to your doorstep</p>
            </div>
          </div>
        </div>
        
        <!-- Pickup Location (shown when pickup selected) -->
        <div id="pickupInfo" class="hidden mb-6 p-4 bg-brand-light rounded-xl animate-fade-in">
          <p class="text-sm text-brand-dark font-medium mb-3">Pickup Location</p>
          <a href="https://maps.app.goo.gl/kiqJ2gdhNNmNhd5T9" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-brand-red hover:underline">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            View on Google Maps
          </a>
        </div>
        
        <!-- Delivery Note (shown when delivery selected) -->
        <div id="deliveryInfo" class="hidden mb-6 p-4 bg-brand-light rounded-xl animate-fade-in">
          <div class="flex items-start gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-red flex-shrink-0 mt-0.5">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <p class="text-sm text-brand-dark">Delivery charges extra as per the location</p>
          </div>
        </div>
        
        <!-- Customer Details Form -->
        <div id="customerForm" class="hidden animate-fade-in">
          <p class="text-sm text-brand-muted mb-4">Your Details</p>
          
          <div class="space-y-4">
            <input type="text" id="customerName" class="form-input" placeholder="Your Name *" required>
            <input type="tel" id="customerPhone" class="form-input" placeholder="Phone Number *" required>
            
            <!-- Address field only for delivery -->
            <div id="addressField" class="hidden">
              <textarea id="customerAddress" class="form-input resize-none" rows="3" placeholder="Delivery Address *"></textarea>
            </div>
          </div>
        </div>
      </div>
      
      <div class="p-6 border-t border-brand-border bg-white">
        <div class="flex justify-between items-center mb-6">
          <span class="text-brand-muted">Total</span>
          <span class="font-display text-2xl text-brand-dark" id="checkoutTotal">Rs 0</span>
        </div>
        <button onclick="sendWhatsAppOrder()" id="whatsappBtn" class="btn-primary w-full" disabled>
          Order via WhatsApp
        </button>
      </div>
    </div>
  </aside>
  
  <!-- WhatsApp Floating Button -->
  <a href="https://wa.me/919824847345?text=Hi%20Bunty%20Kaka!" 
     target="_blank" 
     rel="noopener noreferrer"
     class="fixed bottom-6 right-6 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:shadow-xl hover:scale-110 transition-all z-40"
     aria-label="Chat on WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="white">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
  
  <script>
    // ============================================
    // DATA
    // ============================================
    
    const menuItems = [
      {
        id: 1,
        name: 'Bateka Bhungla',
        description: 'Signature spicy potato cooked in iron kadai with Kathiawadi spices',
        price: 40,
        image: 'https://z-cdn-media.chatglm.cn/files/0f3033a1-23bc-4bdf-87b4-2b55ea9c861a.png?auth_key=1873079545-5db6ed767255465a84d6d0fa54b5d7e8-0-00eb82b1ff88015bc124f902da1cbd4f',
        spice: 3,
        badge: 'Best Seller'
      },
      {
        id: 2,
        name: 'Bhungla Packet',
        description: 'Quick bite-sized portions for on-the-go snacking',
        price: 10,
        image: 'https://z-cdn-media.chatglm.cn/files/59d4d2b7-0478-40dc-bf8c-45498f0e7d1f.png?auth_key=1873079545-8d884bc62d2a4b60b5d246095ea6bafb-0-fdf46b960866a9d06259be7bc862ffcb',
        spice: 2,
        badge: null
      },
      {
        id: 3,
        name: 'Dry Bhungla',
        description: 'Crispy roasted potatoes with extra spice coating',
        price: 50,
        image: 'https://z-cdn-media.chatglm.cn/files/2b9c3848-86ca-4306-b3cd-8afacf133d59.png?auth_key=1873079545-1b8bf09abc7641d5905977df01ca4764-0-020fb015a711ab7ea512fa54ef6a8069',
        spice: 3,
        badge: null
      },
      {
        id: 4,
        name: 'Spicy Bhungla',
        description: 'Extra fiery version with special red chili blend',
        price: 60,
        image: 'https://z-cdn-media.chatglm.cn/files/0f3033a1-23bc-4bdf-87b4-2b55ea9c861a.png?auth_key=1873079545-5db6ed767255465a84d6d0fa54b5d7e8-0-00eb82b1ff88015bc124f902da1cbd4f',
        spice: 4,
        badge: 'Spicy'
      },
      {
        id: 5,
        name: 'Kathiawadi Mix',
        description: 'Combination platter with bhungla, chutney, salad and chaas',
        price: 70,
        image: 'https://z-cdn-media.chatglm.cn/files/59d4d2b7-0478-40dc-bf8c-45498f0e7d1f.png?auth_key=1873079545-8d884bc62d2a4b60b5d246095ea6bafb-0-fdf46b960866a9d06259be7bc862ffcb',
        spice: 3,
        badge: 'Value'
      },
      {
        id: 6,
        name: 'Special Chaas',
        description: 'Refreshing buttermilk with roasted cumin and coriander',
        price: 30,
        image: 'https://z-cdn-media.chatglm.cn/files/2b9c3848-86ca-4306-b3cd-8afacf133d59.png?auth_key=1873079545-1b8bf09abc7641d5905977df01ca4764-0-020fb015a711ab7ea512fa54ef6a8069',
        spice: 0,
        badge: null
      },
      {
        id: 7,
        name: 'Chutney',
        description: 'Fresh homemade garlic and chili chutney',
        price: 40,
        image: 'https://z-cdn-media.chatglm.cn/files/0f3033a1-23bc-4bdf-87b4-2b55ea9c861a.png?auth_key=1873079545-5db6ed767255465a84d6d0fa54b5d7e8-0-00eb82b1ff88015bc124f902da1cbd4f',
        spice: 4,
        badge: null
      },
      {
        id: 8,
        name: 'Salad',
        description: 'Fresh onion, tomato and cucumber with lemon dressing',
        price: 40,
        image: 'https://z-cdn-media.chatglm.cn/files/59d4d2b7-0478-40dc-bf8c-45498f0e7d1f.png?auth_key=1873079545-8d884bc62d2a4b60b5d246095ea6bafb-0-fdf46b960866a9d06259be7bc862ffcb',
        spice: 1,
        badge: null
      },
      {
        id: 9,
        name: 'Chaas',
        description: 'Traditional Gujarati buttermilk',
        price: 20,
        image: 'https://z-cdn-media.chatglm.cn/files/2b9c3848-86ca-4306-b3cd-8afacf133d59.png?auth_key=1873079545-1b8bf09abc7641d5905977df01ca4764-0-020fb015a711ab7ea512fa54ef6a8069',
        spice: 0,
        badge: null
      }
    ];
    
    // ============================================
    // STATE
    // ============================================
    
    let cart = [];
    let orderType = null;
    
    // ============================================
    // INITIALIZATION
    // ============================================
    
    document.addEventListener('DOMContentLoaded', function() {
      renderMenu();
      initScrollReveal();
    });
    
    // ============================================
    // RENDER FUNCTIONS
    // ============================================
    
    function renderMenu() {
      const grid = document.getElementById('menuGrid');
      if (!grid) return;
      
      grid.innerHTML = menuItems.map((item, i) => `
        <article class="menu-card reveal" style="transition-delay: ${i * 0.05}s">
          <div class="relative aspect-[4/3] overflow-hidden">
            <img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover">
            ${item.badge ? `<span class="absolute top-3 left-3 badge">${item.badge}</span>` : ''}
          </div>
          <div class="p-5">
            <div class="flex items-start justify-between gap-4 mb-2">
              <h3 class="font-display text-lg text-brand-dark">${item.name}</h3>
              <p class="font-display text-lg text-brand-red whitespace-nowrap">Rs ${item.price}</p>
            </div>
            <p class="text-sm text-brand-muted mb-4 line-clamp-2">${item.description}</p>
            <div class="flex items-center justify-between">
              <div class="flex gap-1">
                ${[1,2,3,4].map(n => `<span class="spice-dot ${n <= item.spice ? 'active' : ''}"></span>`).join('')}
              </div>
              <button onclick="addToCart(${item.id})" class="text-sm font-medium text-brand-dark hover:text-brand-red transition-colors">
                + Add
              </button>
            </div>
          </div>
        </article>
      `).join('');
    }
    
    function renderCart() {
      const container = document.getElementById('cartItemsContainer');
      const subtotal = document.getElementById('cartSubtotal');
      const badge = document.getElementById('cartBadge');
      const checkoutBtn = document.getElementById('checkoutBtn');
      
      const total = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
      const count = cart.reduce((sum, item) => sum + item.qty, 0);
      
      // Update badge
      if (badge) {
        badge.textContent = count;
        badge.style.opacity = count > 0 ? '1' : '0';
        badge.style.transform = count > 0 ? 'scale(1)' : 'scale(0)';
      }
      
      // Update checkout button
      if (checkoutBtn) {
        checkoutBtn.disabled = cart.length === 0;
      }
      
      // Update subtotal
      if (subtotal) {
        subtotal.textContent = `Rs ${total}`;
      }
      
      // Render cart items
      if (!container) return;
      
      if (cart.length === 0) {
        container.innerHTML = `
          <div class="flex flex-col items-center justify-center h-full text-center">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-brand-border mb-4">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            <p class="text-brand-muted">Your cart is empty</p>
            <button onclick="closeCart(); scrollToMenu();" class="btn-secondary mt-4 text-sm">Browse Menu</button>
          </div>
        `;
        return;
      }
      
      container.innerHTML = cart.map(item => `
        <div class="flex gap-4 pb-4 mb-4 border-b border-brand-border last:border-0">
          <img src="${item.image}" alt="${item.name}" class="w-20 h-20 rounded-xl object-cover">
          <div class="flex-1">
            <h4 class="font-medium text-brand-dark">${item.name}</h4>
            <p class="text-sm text-brand-muted">Rs ${item.price}</p>
            <div class="flex items-center gap-3 mt-2">
              <button onclick="updateQty(${item.id}, -1)" class="qty-btn" aria-label="Decrease quantity">-</button>
              <span class="text-brand-dark font-medium w-6 text-center">${item.qty}</span>
              <button onclick="updateQty(${item.id}, 1)" class="qty-btn" aria-label="Increase quantity">+</button>
            </div>
          </div>
          <button onclick="removeFromCart(${item.id})" class="text-brand-muted hover:text-brand-red transition-colors self-start" aria-label="Remove item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            </svg>
          </button>
        </div>
      `).join('');
    }
    
    // ============================================
    // CART FUNCTIONS
    // ============================================
    
    function addToCart(id) {
      const item = menuItems.find(i => i.id === id);
      if (!item) return;
      
      const existing = cart.find(i => i.id === id);
      if (existing) {
        existing.qty += 1;
      } else {
        cart.push({
          id: item.id,
          name: item.name,
          price: item.price,
          image: item.image,
          qty: 1
        });
      }
      
      renderCart();
      
      // Animate badge
      const badge = document.getElementById('cartBadge');
      if (badge) {
        badge.style.transform = 'scale(1.3)';
        setTimeout(() => {
          badge.style.transform = 'scale(1)';
        }, 200);
      }
    }
    
    function updateQty(id, delta) {
      const item = cart.find(i => i.id === id);
      if (!item) return;
      
      item.qty += delta;
      if (item.qty <= 0) {
        removeFromCart(id);
      } else {
        renderCart();
      }
    }
    
    function removeFromCart(id) {
      cart = cart.filter(i => i.id !== id);
      renderCart();
    }
    
    function openCart() {
      document.getElementById('cartSidebar').classList.add('open');
      document.getElementById('cartOverlay').classList.add('open');
      document.body.style.overflow = 'hidden';
      
      // Reset to step 1
      showCartStep(1);
      renderCart();
    }
    
    function closeCart() {
      document.getElementById('cartSidebar').classList.remove('open');
      document.getElementById('cartOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }
    
    function showCartStep(step) {
      const step1 = document.getElementById('cartStep1');
      const step2 = document.getElementById('cartStep2');
      
      if (step === 1) {
        step1.classList.remove('hidden');
        step2.classList.add('hidden');
      } else {
        step1.classList.add('hidden');
        step2.classList.remove('hidden');
      }
    }
    
    function proceedToCheckout() {
      if (cart.length === 0) return;
      
      showCartStep(2);
      
      // Update checkout total
      const total = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
      document.getElementById('checkoutTotal').textContent = `Rs ${total}`;
      
      // Reset form state
      orderType = null;
      document.querySelectorAll('.radio-option').forEach(el => el.classList.remove('selected'));
      document.getElementById('pickupInfo').classList.add('hidden');
      document.getElementById('deliveryInfo').classList.add('hidden');
      document.getElementById('customerForm').classList.add('hidden');
      document.getElementById('addressField').classList.add('hidden');
      document.getElementById('whatsappBtn').disabled = true;
    }
    
    function backToCart() {
      showCartStep(1);
    }
    
    function selectOrderType(type) {
      orderType = type;
      
      // Update radio UI
      document.querySelectorAll('.radio-option').forEach(el => {
        el.classList.toggle('selected', el.dataset.type === type);
      });
      
      // Show/hide info sections
      const pickupInfo = document.getElementById('pickupInfo');
      const deliveryInfo = document.getElementById('deliveryInfo');
      const customerForm = document.getElementById('customerForm');
      const addressField = document.getElementById('addressField');
      
      pickupInfo.classList.toggle('hidden', type !== 'pickup');
      deliveryInfo.classList.toggle('hidden', type !== 'delivery');
      customerForm.classList.remove('hidden');
      addressField.classList.toggle('hidden', type !== 'delivery');
      
      validateForm();
    }
    
    function validateForm() {
      const name = document.getElementById('customerName').value.trim();
      const phone = document.getElementById('customerPhone').value.trim();
      const address = document.getElementById('customerAddress').value.trim();
      
      const whatsappBtn = document.getElementById('whatsappBtn');
      let isValid = name && phone && orderType;
      
      if (orderType === 'delivery') {
        isValid = isValid && address;
      }
      
      whatsappBtn.disabled = !isValid;
    }
    
    // Add input listeners for validation
    document.addEventListener('DOMContentLoaded', function() {
      ['customerName', 'customerPhone', 'customerAddress'].forEach(id => {
        const el = document.getElementById(id);
        if (el) {
          el.addEventListener('input', validateForm);
        }
      });
    });
    
    function sendWhatsAppOrder() {
      const name = document.getElementById('customerName').value.trim();
      const phone = document.getElementById('customerPhone').value.trim();
      const address = document.getElementById('customerAddress').value.trim();
      
      if (!name || !phone || !orderType) return;
      if (orderType === 'delivery' && !address) return;
      
      // Build order text
      let orderText = `*New Order - ${orderType.toUpperCase()}*\n\n`;
      orderText += `*Customer:* ${name}\n`;
      orderText += `*Phone:* ${phone}\n`;
      
      if (orderType === 'delivery') {
        orderText += `*Address:* ${address}\n`;
      }
      
      orderText += `\n*Order Details:*\n`;
      
      cart.forEach(item => {
        orderText += `- ${item.name} x${item.qty} = Rs ${item.price * item.qty}\n`;
      });
      
      const total = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
      orderText += `\n*Total: Rs ${total}*\n`;
      
      if (orderType === 'delivery') {
        orderText += `\n_Note: Delivery charges extra as per location_\n`;
      }
      
      // Encode for WhatsApp URL
      const encodedText = encodeURIComponent(orderText);
      const whatsappUrl = `https://wa.me/919824847345?text=${encodedText}`;
      
      window.open(whatsappUrl, '_blank');
    }
    
    // ============================================
    // NAVIGATION
    // ============================================
    
    function toggleMobileMenu() {
      const menu = document.getElementById('mobileMenu');
      const isOpen = !menu.classList.contains('hidden');
      
      if (isOpen) {
        menu.style.opacity = '0';
        setTimeout(() => menu.classList.add('hidden'), 300);
      } else {
        menu.classList.remove('hidden');
        setTimeout(() => menu.style.opacity = '1', 10);
      }
    }
    
    function scrollToMenu() {
      document.getElementById('menu').scrollIntoView({ behavior: 'smooth' });
    }
    
    // ============================================
    // SCROLL REVEAL
    // ============================================
    
    function initScrollReveal() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      });
      
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    }
    
    // ============================================
    // KEYBOARD
    // ============================================
    
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        if (document.getElementById('cartSidebar').classList.contains('open')) {
          closeCart();
        }
        if (!document.getElementById('mobileMenu').classList.contains('hidden')) {
          toggleMobileMenu();
        }
      }
    });
  </script>
</body>
</html>
